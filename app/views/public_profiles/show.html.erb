<h1><%= @profile.display_name %>'s profile</h1>

<p>Age: <%= @profile.age %></p>
<p>Gender: <%= @profile.gender.humanize %></p>
<p>Location: <%= @profile.location %></p>
<p>Occupation: <%= @profile.occupation %></p>
<p>Bio: <%= @profile.bio %></p>

<% if user_signed_in? && current_user != @profile.user %>
  <% if @liked %>
    <%= button_to "Unlike",
        public_profile_like_path(@profile),
        method: :delete %>
  <% else %>
    <%= button_to "Like",
        public_profile_like_path(@profile),
        method: :post %>
  <% end %>
<% end %>

<p><%= link_to "Back to Browse", public_profiles_path %></p>
