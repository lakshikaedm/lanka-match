<%= form_with model: @profile, url: profile_path do |form| %>
  <% if @profile.errors.any? %>
    <div>
      <h2><%= pluralize(@profile.errors.count, "error") %> prevented this profile from being saved. </h2>
      <ul>
        <% @profile.error.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :display_name %><br>
    <%= form.text_field :display_name %>
  </div>

  <div>
    <%= form.label :birth_date %><br>
    <%= form.date_field :birth_date %>
  </div>

  <div>
    <%= form.label :gender %><br>
    <%= form.select :gender, Profile.genders.keys.map { |key| [key.humanize, key] }, prompt: "Select gender" %>
  </div>

  <div>
    <%= form.label :location %><br>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :bio %><br>
    <%= form.text_area :bio %>
  </div>

  <div>
    <%= form.label :occupation %><br>
    <%= form.text_field :occupation %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
